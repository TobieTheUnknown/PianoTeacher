<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PianoTeacher" parent="Theme.AppCompat.NoActionBar">
        <!-- Pre-API-31 splash fallback: a solid brand-coloured window background
             so the launch never flashes white. The API 31+ platform SplashScreen
             attributes live in values-v31/themes.xml. -->
        <item name="android:windowBackground">@color/brand_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
