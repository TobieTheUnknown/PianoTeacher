    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Keyboard (7 white keys), tightened into the central safe circle.
         Keys span x 33->75, y 52->80. -->
    <path
        android:fillColor="#e8eaf0"
        android:pathData="M33,52h5.6v28h-5.6zM45.2,52h5.6v28h-5.6zM51.3,52h5.6v28h-5.6zM57.4,52h5.6v28h-5.6zM69.4,52h5.6v28h-5.6z" />
    <!-- left-hand key (pink) -->
    <path
        android:fillColor="#ec4899"
        android:pathData="M39.1,52h5.6v28h-5.6z" />
    <!-- right-hand key (cyan) -->
    <path
        android:fillColor="#22d3ee"
        android:pathData="M63.3,52h5.6v28h-5.6z" />
    <!-- black keys -->
    <path
        android:fillColor="#0a0c10"
        android:pathData="M37.8,52h3.6v17h-3.6zM43.9,52h3.6v17h-3.6zM56,52h3.6v17h-3.6zM62.1,52h3.6v17h-3.6zM68.2,52h3.6v17h-3.6z" />

