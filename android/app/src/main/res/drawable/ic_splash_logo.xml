<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ animated splash icon for Piano Teacher.
     Transparent background (the splash background colour #0a0c10 comes from the
     theme). Content is the keyboard + rising note accent from the master logo,
     centred and inset so it stays inside the circular splash mask. The Android
     splash icon canvas is 108x108 with the inner ~66dp visible inside the mask;
     here the artwork is drawn directly into that safe central area. -->
